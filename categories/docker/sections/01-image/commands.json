  { "name": "docker push", "description": "イメージをコンテナレジストリにプッシュする", "syntax": "docker push <image>", "example": "docker push myrepo/myapp:v1.0", "tags": ["image", "registry", "push"], "url": "" },
  { "name": "docker pull", "description": "コンテナレジストリからイメージをプルする", "syntax": "docker pull <image>", "example": "docker pull nginx:latest", "tags": ["image", "registry", "pull"], "url": "" },
