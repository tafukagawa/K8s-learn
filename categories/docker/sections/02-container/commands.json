  { "name": "docker ps -a", "description": "停止中のコンテナを含む全コンテナ一覧を表示する", "syntax": "docker ps -a", "example": "docker ps -a", "tags": ["container", "list"], "url": "" },
  { "name": "docker stop", "description": "実行中のコンテナにSIGTERMを送り正常停止する", "syntax": "docker stop <container> [container...]", "example": "docker stop mycontainer", "tags": ["container", "stop"], "url": "" },
  { "name": "docker kill", "description": "コンテナにSIGKILLを送り強制停止する", "syntax": "docker kill <container> [container...]", "example": "docker kill mycontainer", "tags": ["container", "stop", "kill"], "url": "" },
